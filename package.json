{
  "name": "@fanatyx/nestjs-observability",
  "version": "1.0.14",
  "description": "A runnable test app for the NestJS Observability module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build:all": "rimraf dist && tsc -p tsconfig.json",
